# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_USER=hackflow
POSTGRES_PASSWORD=hackflow_secret
POSTGRES_DB=hackflow
DATABASE_URL=postgresql+asyncpg://hackflow:hackflow_secret@postgres:5432/hackflow

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── ChromaDB ─────────────────────────────────────────────────────────────────
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-this-to-a-random-256-bit-secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ─── GitHub OAuth ─────────────────────────────────────────────────────────────
GITHUB_CLIENT_ID=your_github_client_id
GITHUB_CLIENT_SECRET=your_github_client_secret
GITHUB_REDIRECT_URI=http://localhost:8000/api/v1/auth/github/callback
# PAT of the service account added as collaborator to private repos
GITHUB_BOT_TOKEN=your_github_bot_token

# ─── Discord ──────────────────────────────────────────────────────────────────
DISCORD_BOT_TOKEN=your_discord_bot_token
DISCORD_GUILD_ID=your_discord_guild_id

# ─── Google Gemini ────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key

# ─── Email / SMTP ─────────────────────────────────────────────────────────────
# Dev: Mailtrap → SMTP_HOST=sandbox.smtp.mailtrap.io SMTP_PORT=2525
# Prod: Gmail → SMTP_HOST=smtp.gmail.com SMTP_PORT=587
SMTP_HOST=sandbox.smtp.mailtrap.io
SMTP_PORT=2525
SMTP_USER=your_mailtrap_user
SMTP_PASS=your_mailtrap_pass
EMAIL_FROM=noreply@hackflow.dev

# ─── App ──────────────────────────────────────────────────────────────────────
ENVIRONMENT=development
FRONTEND_URL=http://localhost:5173
BACKEND_URL=http://localhost:8000
